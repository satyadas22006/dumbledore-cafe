                      className={`px-5 py-3 rounded-2xl font-black border-4 border-[#472C20] text-sm transition-all ${favoriteDish === item ? 'bg-[#FFE08A] ring-4 ring-[#FF9F29]/30 scale-105' : 'bg-white'}`}
